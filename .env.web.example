# NeuraVPN web cabinet API
# Copy to /opt/neuravpn_vk/.env.web on VPS and fill secrets.

DB_DSN=postgres://vpnbot:supersecret@localhost:5432/vpnbot?sslmode=disable
WEB_PORT=8090
WEB_AUTH_SECRET=CHANGE_ME_LONG_RANDOM_SECRET

# For testing by plain http://VPS_IP only. Use true with HTTPS/domain.
WEB_COOKIE_SECURE=false
WEB_COOKIE_SAMESITE=lax
WEB_PUBLIC_BASE_URL=http://YOUR_VPS_IP

# If frontend is served from the same host through nginx /api, leave empty.
WEB_CORS_ORIGIN=

# Existing bot/payment/subscription settings reused by web API.
YOOKASSA_STORE_ID=CHANGE_ME
YOOKASSA_API_KEY=CHANGE_ME
SUB_BASE_URL=
MERGED_SUB_PUBLIC_BASE_URL=
MERGED_SUB_SECRET=

# Optional SMTP. If empty, login codes are printed to web API logs.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
